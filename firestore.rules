rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // ADMIN ONLY - Productos (CRUD completo)
    // ============================================
    match /productos/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ============================================
    // ADMIN ONLY - Categorías (Read para clientes)
    // ============================================
    match /categorias/{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ============================================
    // ADMIN LIST - Whitelist de UIDs permitidos
    // ============================================
    match /admins/allowedUids {
      allow read: if request.auth != null;
      allow write: if false;  // Solo por Firebase Console
    }

    // ============================================
    // AUDIT LOGS - Solo lectura/escritura para admins
    // ============================================
    match /audit_logs/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ============================================
    // DENEGAR TODO LO DEMÁS
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ============================================
    // FUNCIÓN: Verificar si es Admin
    // ============================================
    function isAdmin() {
      return request.auth != null &&
             request.auth.uid in get(/databases/$(database)/documents/admins/allowedUids).data.uids;
    }
  }
}
