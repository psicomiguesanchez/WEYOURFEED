# WEYOURFEED - Variables de Configuración
# ==========================================
#
# DESARROLLO LOCAL:
# - Copia este archivo a .env.local
# - .env.local está en .gitignore (NO sube a Git)
# - Nunca comitees .env.local
#
# PRODUCCIÓN (Vercel):
# - Usa Vercel Console → Settings → Environment Variables
# - NO pongas valores en este archivo
# - Vercel inyecta las variables en tiempo de build
#
# ==========================================

# Credenciales Admin (SOLO desarrollo local)
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# Firebase Configuration
# PELIGRO: Nunca hardcódees el API_KEY en el código HTML
# Debe cargarse desde variables de entorno o Vercel
FIREBASE_API_KEY=tu_nueva_api_key_aqui
FIREBASE_AUTH_DOMAIN=weyourfeed.firebaseapp.com
FIREBASE_PROJECT_ID=weyourfeed
FIREBASE_STORAGE_BUCKET=weyourfeed.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=108057920918
FIREBASE_APP_ID=1:108057920918:web:b2434484b00c4c6f0bc9b7
FIREBASE_MEASUREMENT_ID=G-79ZNK0SZHE